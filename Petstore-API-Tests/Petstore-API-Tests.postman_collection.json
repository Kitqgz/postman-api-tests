        {
          "name": "200:Find pet by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Name id status is okay\", function () {\r",
                  "    var jsonData = pm.response.json();\r",
                  "    pm.expect(jsonData.name).to.eql(\"doggie\");\r",
                  "    pm.expect(jsonData.id).to.eql(9223372016900121823);\r",
                  "    pm.expect(jsonData.status).to.eql(\"available\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Connection is present\", function () {\r",
                  "    pm.response.to.have.header(\"Connection\");\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Status code is not 404\", function () {\r",
                  "    pm.response.to.not.have.status(404);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
