                  "script": {
                    "exec": [
                      "const json = pm.response.json();\r",
                      "\r",
                      "pm.environment.set(\"token\", json.accessToken);"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
